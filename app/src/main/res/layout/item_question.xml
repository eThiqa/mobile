<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/spacing_xs"
    style="@style/Widget.AlMizan.Card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <TextView
            android:id="@+id/tvQuestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="?attr/colorOnSurface"/>

        <TextView
            android:id="@+id/tvDateQuestion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:layout_marginTop="@dimen/spacing_xs"/>

        <TextView
            android:id="@+id/tvEnAttente"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏳ En attente de réponse"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="@color/semantic_warning"
            android:layout_marginTop="@dimen/spacing_sm"
            android:visibility="gone"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorSurfaceVariant"
            android:layout_marginVertical="@dimen/spacing_sm"/>

        <TextView
            android:id="@+id/tvReponse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorPrimary"
            android:background="?attr/colorSurfaceVariant"
            android:padding="@dimen/spacing_sm"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tvDateReponse"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:layout_marginTop="@dimen/spacing_xs"
            android:visibility="gone"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
