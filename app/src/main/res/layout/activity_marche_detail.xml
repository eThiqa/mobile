<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <ProgressBar android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:indeterminateTint="?attr/colorPrimary"
            android:visibility="gone"/>

        <!-- Card principale -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            style="@style/Widget.AlMizan.Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <TextView android:id="@+id/tvTitre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceTitleLarge"
                    android:textColor="?attr/colorOnSurface"/>

                <TextView android:id="@+id/tvReference"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceLabelMedium"
                    android:layout_marginTop="@dimen/spacing_xs"/>

                <TextView android:id="@+id/tvWilaya"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="@color/semantic_info"
                    android:layout_marginTop="@dimen/spacing_sm"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card infos -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            style="@style/Widget.AlMizan.Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Informations du marché"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="?attr/colorPrimary"
                    android:layout_marginBottom="@dimen/spacing_md"/>

                <!-- Lignes infos -->
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/spacing_sm">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Service Contractant"
                        android:textAppearance="?attr/textAppearanceLabelMedium"/>
                    <TextView android:id="@+id/tvServiceContractant"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurface"
                        android:gravity="end"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/spacing_sm">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Type de marché"
                        android:textAppearance="?attr/textAppearanceLabelMedium"/>
                    <TextView android:id="@+id/tvType"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurface"
                        android:gravity="end"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/spacing_sm">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Mode de passation"
                        android:textAppearance="?attr/textAppearanceLabelMedium"/>
                    <TextView android:id="@+id/tvMode"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurface"
                        android:gravity="end"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/spacing_sm">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Secteur"
                        android:textAppearance="?attr/textAppearanceLabelMedium"/>
                    <TextView android:id="@+id/tvSecteur"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurface"
                        android:gravity="end"/>
                </LinearLayout>

                <!-- Budget (optionnel) -->
                <LinearLayout android:id="@+id/rowBudget"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:visibility="gone">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Budget estimatif"
                        android:textAppearance="?attr/textAppearanceLabelMedium"/>
                    <TextView android:id="@+id/tvBudget"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/sovereign_gold"
                        android:textStyle="bold"
                        android:gravity="end"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card dates -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_lg"
            style="@style/Widget.AlMizan.Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅 Calendrier"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="?attr/colorPrimary"
                    android:layout_marginBottom="@dimen/spacing_md"/>

                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="@dimen/spacing_sm">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Publication"
                        android:textAppearance="?attr/textAppearanceLabelMedium"/>
                    <TextView android:id="@+id/tvDatePublication"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurface"
                        android:gravity="end"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="@dimen/spacing_sm">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Limite retrait"
                        android:textAppearance="?attr/textAppearanceLabelMedium"/>
                    <TextView android:id="@+id/tvDateRetrait"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/semantic_warning"
                        android:gravity="end"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Limite dépôt"
                        android:textAppearance="?attr/textAppearanceLabelMedium"/>
                    <TextView android:id="@+id/tvDateSoumission"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/semantic_error"
                        android:textStyle="bold"
                        android:gravity="end"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Boutons actions -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDownloadCdc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📥 Télécharger le CDC"
            style="@style/Widget.AlMizan.Button.Outlined"
            android:layout_marginBottom="@dimen/spacing_sm"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnQuestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="❓ Questions / Éclaircissements"
            style="@style/Widget.AlMizan.Button.Outlined"
            app:strokeColor="@color/semantic_info"
            android:textColor="@color/semantic_info"
            android:layout_marginBottom="@dimen/spacing_sm"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSoumettre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📤 Déposer une offre"
            style="@style/Widget.AlMizan.Button"
            android:layout_marginBottom="@dimen/spacing_lg"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>
