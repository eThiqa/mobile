<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <!-- Info marché -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            style="@style/Widget.AlMizan.Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Marché concerné"
                    android:textAppearance="?attr/textAppearanceLabelSmall"/>

                <TextView
                    android:id="@+id/tvMarcheTitre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="?attr/colorOnSurface"/>

                <TextView
                    android:id="@+id/tvDelaiInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="@color/semantic_warning"
                    android:background="@drawable/bg_warning_light"
                    android:padding="@dimen/spacing_sm"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Motif -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Motif du recours *"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="?attr/colorOnBackground"
            android:layout_marginBottom="@dimen/spacing_sm"/>

        <RadioGroup android:id="@+id/rgMotif"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton android:id="@+id/rbIrregularite"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Irrégularité de procédure"
                android:padding="@dimen/spacing_sm"
                android:textAppearance="?attr/textAppearanceBodyMedium"/>

            <RadioButton android:id="@+id/rbFavoritisme"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Suspicion de favoritisme"
                android:padding="@dimen/spacing_sm"
                android:textAppearance="?attr/textAppearanceBodyMedium"/>

            <RadioButton android:id="@+id/rbCriteres"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Critères d'évaluation non respectés"
                android:padding="@dimen/spacing_sm"
                android:textAppearance="?attr/textAppearanceBodyMedium"/>

            <RadioButton android:id="@+id/rbAutre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Autre"
                android:padding="@dimen/spacing_sm"
                android:textAppearance="?attr/textAppearanceBodyMedium"/>
        </RadioGroup>

        <!-- Contenu du recours -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:hint="Détaillez votre recours *"
            style="@style/Widget.AlMizan.TextInputLayout">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etContenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="6"
                android:maxLines="12"
                android:gravity="top"
                android:textAppearance="?attr/textAppearanceBodyMedium"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Pièce jointe -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnJoindre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="📎 Joindre un document (PDF)"
            style="@style/Widget.AlMizan.Button.Outlined"/>

        <TextView
            android:id="@+id/tvPieceJointe"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:text="Aucun document joint"
            android:textAppearance="?attr/textAppearanceLabelSmall"/>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/spacing_md"
            android:indeterminateTint="?attr/colorPrimary"
            android:visibility="gone"/>

        <!-- Bouton soumettre -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSoumettre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_xl"
            android:text="Déposer le recours"
            style="@style/Widget.AlMizan.Button"/>

    </LinearLayout>
</ScrollView>
