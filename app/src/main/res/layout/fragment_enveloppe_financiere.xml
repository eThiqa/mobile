<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <!-- Info chiffrement -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            style="@style/Widget.AlMizan.Card"
            app:cardBackgroundColor="?attr/colorSurfaceVariant">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔒 Sécurité"
                    android:textAppearance="?attr/textAppearanceTitleSmall"
                    android:textColor="?attr/colorPrimary"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Votre offre financière sera chiffrée et ne sera visible qu'au moment de l'ouverture officielle des plis par la commission."
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginTop="@dimen/spacing_xs"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Montant -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            android:hint="Montant total de l'offre (DA) *"
            style="@style/Widget.AlMizan.TextInputLayout"
            app:suffixText="DA">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMontant"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textAppearance="?attr/textAppearanceBodyMedium"/>
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BPU / DQE (PDF) *"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="?attr/colorOnBackground"
            android:layout_marginBottom="@dimen/spacing_sm"/>

        <TextView
            android:id="@+id/tvDocFinancierNom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aucun document sélectionné"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:padding="@dimen/spacing_md"
            android:background="@drawable/bg_dashed_border"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_md"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUploadFinancier"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📎 Sélectionner le BPU/DQE"
            style="@style/Widget.AlMizan.Button.Outlined"/>

    </LinearLayout>
</ScrollView>
