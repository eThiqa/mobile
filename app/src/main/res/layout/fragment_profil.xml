<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header avec avatar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="32dp"
            android:paddingBottom="28dp"
            android:background="?attr/colorPrimary">

            <!-- Avatar initiales -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:id="@+id/tvAvatar"
                    android:gravity="center"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorPrimary"
                    android:background="@drawable/bg_avatar_circle"
                    android:text="OE"/>
            </FrameLayout>

            <TextView
                android:id="@+id/tvNomComplet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nom Complet"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnPrimary"
                android:layout_marginTop="12dp"/>

            <TextView
                android:id="@+id/tvRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Opérateur Économique"
                android:textSize="13sp"
                android:textColor="#AADFC0"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tvEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#AADFC0"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Section Informations -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Informations personnelles"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary"
                android:layout_marginBottom="10dp"/>

            <!-- Nom -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nom"
                style="@style/Widget.AlMizan.TextInputLayout"
                android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:enabled="false"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Prénom -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Prénom"
                style="@style/Widget.AlMizan.TextInputLayout"
                android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPrenom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:enabled="false"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Téléphone -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Téléphone"
                style="@style/Widget.AlMizan.TextInputLayout"
                android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTelephone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone"
                    android:enabled="false"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Séparateur -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorOutline"
                android:layout_marginVertical="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Informations entreprise"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary"
                android:layout_marginBottom="10dp"/>

            <!-- Raison sociale -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Raison sociale"
                style="@style/Widget.AlMizan.TextInputLayout"
                android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRaisonSociale"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:enabled="false"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Registre commerce -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="N° Registre de Commerce"
                style="@style/Widget.AlMizan.TextInputLayout"
                android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRegistreCommerce"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:enabled="false"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Bouton Modifier / Sauvegarder -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnModifier"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:text="✏️ Modifier le profil"
                style="@style/Widget.AlMizan.Button.Outlined"
                app:cornerRadius="12dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSauvegarder"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:text="💾 Sauvegarder"
                style="@style/Widget.AlMizan.Button"
                app:cornerRadius="12dp"
                android:visibility="gone"/>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:indeterminateTint="?attr/colorPrimary"
                android:visibility="gone"/>

            <!-- Séparateur -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorOutline"
                android:layout_marginVertical="20dp"/>

            <!-- Bouton Déconnexion -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeconnexion"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🚪 Se déconnecter"
                android:textColor="@color/status_red"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/status_red"
                app:cornerRadius="12dp"
                android:layout_marginBottom="32dp"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>