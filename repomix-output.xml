        <TextView
            android:id="@+id/tvDocFinancierNom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aucun document sélectionné"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:padding="@dimen/spacing_md"
            android:background="@drawable/bg_dashed_border"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_md"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUploadFinancier"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📎 Sélectionner le BPU/DQE"
            style="@style/Widget.AlMizan.Button.Outlined"/>

    </LinearLayout>
</ScrollView>
</file>

