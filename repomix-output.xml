<file path="app/src/main/res/layout/fragment_dashboard.xml">
<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingTop="@dimen/spacing_lg"
            android:paddingBottom="28dp"
            android:background="@drawable/bg_header_green">

            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dashboard_greeting"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="@color/neutral_light"/>

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Opérateur Économique"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textColor="@color/neutral_white"
                android:layout_marginTop="@dimen/spacing_xs"/>
        </LinearLayout>

        <!-- Contenu principal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <!-- Cartes statistiques -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginTop="-20dp">

                <!-- AO ouverts -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardNouveauxMarches"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="@dimen/spacing_xs"
                    style="@style/Widget.AlMizan.Card"
                    android:foreground="?attr/selectableItemBackground">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="@dimen/spacing_sm">
                        <TextView
                            android:id="@+id/tvMarchesOuverts"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textAppearance="?attr/textAppearanceHeadlineSmall"
                            android:textColor="?attr/colorPrimary"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dashboard_ao_ouverts"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:gravity="center"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Mes dépôts -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardMesSoumissions"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="@dimen/spacing_xs"
                    style="@style/Widget.AlMizan.Card"
                    android:foreground="?attr/selectableItemBackground">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="@dimen/spacing_sm">
                        <TextView
                            android:id="@+id/tvMesSoumissions"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textAppearance="?attr/textAppearanceHeadlineSmall"
                            android:textColor="@color/semantic_info"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dashboard_mes_depots"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:gravity="center"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Recours -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardRecours"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="@dimen/spacing_xs"
                    style="@style/Widget.AlMizan.Card"
                    android:foreground="?attr/selectableItemBackground">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="@dimen/spacing_sm">
                        <TextView
                            android:id="@+id/tvRecoursPossibles"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textAppearance="?attr/textAppearanceHeadlineSmall"
                            android:textColor="@color/semantic_warning"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dashboard_recours"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:gravity="center"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Dernières alertes -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dashboard_dernières_alertes"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:layout_marginTop="@dimen/spacing_lg"
                android:layout_marginBottom="@dimen/spacing_sm"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecentNotifications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

            <!-- Marchés récents -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Marchés récents"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:layout_marginTop="@dimen/spacing_lg"
                android:layout_marginBottom="@dimen/spacing_sm"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecentMarches"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="@dimen/spacing_md"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
</file>

