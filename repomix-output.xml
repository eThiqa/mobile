<file path="app/src/main/res/layout/activity_marche_detail.xml">
<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <ProgressBar android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:indeterminateTint="?attr/colorPrimary"
            android:visibility="gone"/>

        <!-- Card principale -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            style="@style/Widget.AlMizan.Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <TextView android:id="@+id/tvTitre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceTitleLarge"
                    android:textColor="?attr/colorOnSurface"/>

                <TextView android:id="@+id/tvReference"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceLabelMedium"
                    android:layout_marginTop="@dimen/spacing_xs"/>

                <TextView android:id="@+id/tvWilaya"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="@color/semantic_info"
                    android:layout_marginTop="@dimen/spacing_sm"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card infos -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            style="@style/Widget.AlMizan.Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Informations du marché"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="?attr/colorPrimary"
                    android:layout_marginBottom="@dimen/spacing_md"/>

                <!-- Lignes infos -->
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/spacing_sm">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Service Contractant"
                        android:textAppearance="?attr/textAppearanceLabelMedium"/>
                    <TextView android:id="@+id/tvServiceContractant"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurface"
                        android:gravity="end"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/spacing_sm">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Type de marché"
                        android:textAppearance="?attr/textAppearanceLabelMedium"/>
                    <TextView android:id="@+id/tvType"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurface"
                        android:gravity="end"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/spacing_sm">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Mode de passation"
                        android:textAppearance="?attr/textAppearanceLabelMedium"/>
                    <TextView android:id="@+id/tvMode"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurface"
                        android:gravity="end"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/spacing_sm">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Secteur"
                        android:textAppearance="?attr/textAppearanceLabelMedium"/>
                    <TextView android:id="@+id/tvSecteur"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurface"
                        android:gravity="end"/>
                </LinearLayout>

                <!-- Budget (optionnel) -->
                <LinearLayout android:id="@+id/rowBudget"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:visibility="gone">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Budget estimatif"
                        android:textAppearance="?attr/textAppearanceLabelMedium"/>
                    <TextView android:id="@+id/tvBudget"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/sovereign_gold"
                        android:textStyle="bold"
                        android:gravity="end"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card dates -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_lg"
            style="@style/Widget.AlMizan.Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅 Calendrier"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="?attr/colorPrimary"
                    android:layout_marginBottom="@dimen/spacing_md"/>

                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="@dimen/spacing_sm">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Publication"
                        android:textAppearance="?attr/textAppearanceLabelMedium"/>
                    <TextView android:id="@+id/tvDatePublication"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurface"
                        android:gravity="end"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="@dimen/spacing_sm">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Limite retrait"
                        android:textAppearance="?attr/textAppearanceLabelMedium"/>
                    <TextView android:id="@+id/tvDateRetrait"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/semantic_warning"
                        android:gravity="end"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Limite dépôt"
                        android:textAppearance="?attr/textAppearanceLabelMedium"/>
                    <TextView android:id="@+id/tvDateSoumission"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/semantic_error"
                        android:textStyle="bold"
                        android:gravity="end"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Boutons actions -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDownloadCdc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📥 Télécharger le CDC"
            style="@style/Widget.AlMizan.Button.Outlined"
            android:layout_marginBottom="@dimen/spacing_sm"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnQuestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="❓ Questions / Éclaircissements"
            style="@style/Widget.AlMizan.Button.Outlined"
            app:strokeColor="@color/semantic_info"
            android:textColor="@color/semantic_info"
            android:layout_marginBottom="@dimen/spacing_sm"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSoumettre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📤 Déposer une offre"
            style="@style/Widget.AlMizan.Button"
            android:layout_marginBottom="@dimen/spacing_lg"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>
</file>

<file path="app/src/main/res/layout/activity_notes_detail.xml">
<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <ProgressBar android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:indeterminateTint="?attr/colorPrimary"
            android:visibility="gone"/>

        <TextView android:id="@+id/tvMarcheTitre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:textColor="?attr/colorOnBackground"
            android:layout_marginBottom="@dimen/spacing_md"/>

        <!-- Notes cards -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            style="@style/Widget.AlMizan.Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Détail des notes"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="?attr/colorPrimary"
                    android:layout_marginBottom="@dimen/spacing_md"/>

                <!-- Note admin -->
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/spacing_md">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Administrative"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant"/>
                    <TextView android:id="@+id/tvNoteAdmin"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="?attr/colorOnSurface"/>
                </LinearLayout>

                <!-- Note technique -->
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/spacing_md">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Technique"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant"/>
                    <TextView android:id="@+id/tvNoteTechnique"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/semantic_info"/>
                </LinearLayout>

                <!-- Note financière -->
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/spacing_md">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Financière"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant"/>
                    <TextView android:id="@+id/tvNoteFinanciere"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/semantic_warning"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="?attr/colorSurfaceVariant"
                    android:layout_marginVertical="@dimen/spacing_sm"/>

                <!-- Note globale -->
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Note globale"
                        android:textAppearance="?attr/textAppearanceTitleLarge"
                        android:textColor="?attr/colorOnSurface"/>
                    <TextView android:id="@+id/tvNoteGlobale"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceHeadlineMedium"
                        android:textColor="?attr/colorPrimary"/>
                </LinearLayout>

                <TextView android:id="@+id/tvRang"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceTitleSmall"
                    android:textColor="@color/sovereign_gold"
                    android:textStyle="bold"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Observations -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_xl"
            style="@style/Widget.AlMizan.Card">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Observations de la commission"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="?attr/colorPrimary"
                    android:layout_marginBottom="@dimen/spacing_sm"/>
                <TextView android:id="@+id/tvObservations"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorOnSurface"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
</file>

<file path="app/src/main/res/layout/activity_otp.xml">
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/spacing_xl"
    android:gravity="center_horizontal"
    android:background="?android:attr/colorBackground">

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="60dp"
        android:src="@drawable/ic_otp_shield"
        android:contentDescription="Sécurité"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Vérification 2FA"
        android:textAppearance="?attr/textAppearanceHeadlineSmall"
        android:textColor="?attr/colorOnBackground"
        android:layout_marginTop="@dimen/spacing_lg"/>

    <TextView
        android:id="@+id/tvEmailInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:gravity="center"
        android:layout_marginTop="@dimen/spacing_sm"
        android:layout_marginBottom="@dimen/spacing_xl"/>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Code OTP (6 chiffres)"
        style="@style/Widget.AlMizan.TextInputLayout"
        app:startIconDrawable="@drawable/ic_otp_code">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etOtp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberPassword"
            android:maxLength="6"
            android:letterSpacing="0.5"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:gravity="center"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnVerify"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_lg"
        android:text="Vérifier"
        style="@style/Widget.AlMizan.Button"/>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:indeterminateTint="?attr/colorPrimary"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/tvResend"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:text="Renvoyer le code"
        android:textColor="?attr/colorPrimary"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:padding="@dimen/spacing_sm"/>

</LinearLayout>
</file>

<file path="app/src/main/res/layout/activity_questions.xml">
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground">

    <TextView
        android:id="@+id/tvMarcheTitre"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_md"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:textColor="@color/neutral_white"
        android:background="?attr/colorPrimary"
        android:maxLines="2"
        android:ellipsize="end"/>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/spacing_md"
        android:indeterminateTint="?attr/colorPrimary"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Aucune question posée pour ce marché"
        android:gravity="center"
        android:padding="@dimen/spacing_xl"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvQuestions"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="@dimen/spacing_sm"
        android:clipToPadding="false"/>

    <!-- Zone saisie question -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md"
        android:background="?attr/colorSurface"
        android:elevation="4dp">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Votre question (anonyme)"
            style="@style/Widget.AlMizan.TextInputLayout">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etQuestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="2"
                android:maxLines="4"
                android:textAppearance="?attr/textAppearanceBodyMedium"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPoserQuestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="Envoyer la question"
            style="@style/Widget.AlMizan.Button"/>
    </LinearLayout>
</LinearLayout>
</file>

<file path="app/src/main/res/layout/activity_recours.xml">
<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <!-- Info marché -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            style="@style/Widget.AlMizan.Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Marché concerné"
                    android:textAppearance="?attr/textAppearanceLabelSmall"/>

                <TextView
                    android:id="@+id/tvMarcheTitre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="?attr/colorOnSurface"/>

                <TextView
                    android:id="@+id/tvDelaiInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="@color/semantic_warning"
                    android:background="@drawable/bg_warning_light"
                    android:padding="@dimen/spacing_sm"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Motif -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Motif du recours *"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="?attr/colorOnBackground"
            android:layout_marginBottom="@dimen/spacing_sm"/>

        <RadioGroup android:id="@+id/rgMotif"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton android:id="@+id/rbIrregularite"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Irrégularité de procédure"
                android:padding="@dimen/spacing_sm"
                android:textAppearance="?attr/textAppearanceBodyMedium"/>

            <RadioButton android:id="@+id/rbFavoritisme"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Suspicion de favoritisme"
                android:padding="@dimen/spacing_sm"
                android:textAppearance="?attr/textAppearanceBodyMedium"/>

            <RadioButton android:id="@+id/rbCriteres"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Critères d'évaluation non respectés"
                android:padding="@dimen/spacing_sm"
                android:textAppearance="?attr/textAppearanceBodyMedium"/>

            <RadioButton android:id="@+id/rbAutre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Autre"
                android:padding="@dimen/spacing_sm"
                android:textAppearance="?attr/textAppearanceBodyMedium"/>
        </RadioGroup>

        <!-- Contenu du recours -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:hint="Détaillez votre recours *"
            style="@style/Widget.AlMizan.TextInputLayout">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etContenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="6"
                android:maxLines="12"
                android:gravity="top"
                android:textAppearance="?attr/textAppearanceBodyMedium"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Pièce jointe -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnJoindre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="📎 Joindre un document (PDF)"
            style="@style/Widget.AlMizan.Button.Outlined"/>

        <TextView
            android:id="@+id/tvPieceJointe"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:text="Aucun document joint"
            android:textAppearance="?attr/textAppearanceLabelSmall"/>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/spacing_md"
            android:indeterminateTint="?attr/colorPrimary"
            android:visibility="gone"/>

        <!-- Bouton soumettre -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSoumettre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_xl"
            android:text="Déposer le recours"
            style="@style/Widget.AlMizan.Button"/>

    </LinearLayout>
</ScrollView>
</file>

<file path="app/src/main/res/layout/activity_register.xml">
<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <!-- Section : Identité personnelle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Identité personnelle"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:layout_marginTop="@dimen/spacing_sm"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:weightSum="2">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_xs"
                android:hint="Nom *"
                style="@style/Widget.AlMizan.TextInputLayout">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_xs"
                android:hint="Prénom *"
                style="@style/Widget.AlMizan.TextInputLayout">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPrenom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:hint="Adresse email *"
            style="@style/Widget.AlMizan.TextInputLayout"
            app:startIconDrawable="@drawable/ic_email">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:hint="Téléphone *"
            style="@style/Widget.AlMizan.TextInputLayout"
            app:startIconDrawable="@drawable/ic_phone">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTelephone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="phone"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Section : Identité entreprise -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Identité de l'entreprise"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="?attr/colorPrimary"
            android:layout_marginTop="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_sm"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Raison sociale *"
            style="@style/Widget.AlMizan.TextInputLayout">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRaisonSociale"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapWords"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:hint="N° Registre de Commerce *"
            style="@style/Widget.AlMizan.TextInputLayout">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRegistreCommerce"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapCharacters"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ✅ Secteur corrigé : ExposedDropdownMenu + AutoCompleteTextView -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:hint="Secteur d'activité *"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
            <AutoCompleteTextView
                android:id="@+id/actvSecteur"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:focusable="false"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Section : Sécurité -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sécurité du compte"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="?attr/colorPrimary"
            android:layout_marginTop="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_sm"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Mot de passe * (8 car. min.)"
            style="@style/Widget.AlMizan.TextInputLayout"
            app:endIconMode="password_toggle"
            app:startIconDrawable="@drawable/ic_lock">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:hint="Confirmer le mot de passe *"
            style="@style/Widget.AlMizan.TextInputLayout"
            app:endIconMode="password_toggle"
            app:startIconDrawable="@drawable/ic_lock">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"/>
        </com.google.android.material.textfield.TextInputLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/spacing_md"
            android:indeterminateTint="?attr/colorPrimary"
            android:visibility="gone"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:layout_marginBottom="@dimen/spacing_xl"
            android:text="Créer mon compte"
            style="@style/Widget.AlMizan.Button"/>

    </LinearLayout>
</ScrollView>
</file>

<file path="app/src/main/res/layout/activity_scan_document.xml">
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Viewfinder caméra -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/panelBottom"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Overlay guide -->
    <View
        android:layout_width="260dp"
        android:layout_height="180dp"
        android:background="@drawable/scan_overlay_border"
        app:layout_constraintTop_toTopOf="@id/previewView"
        app:layout_constraintBottom_toBottomOf="@id/previewView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Centrez le document dans le cadre"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:textColor="@color/neutral_white"
        android:background="#88000000"
        android:padding="@dimen/spacing_sm"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="@dimen/spacing_md"/>

    <!-- Panel inférieur -->
    <LinearLayout
        android:id="@+id/panelBottom"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/colorSurface"
        android:padding="@dimen/spacing_md"
        android:gravity="center_horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:indeterminateTint="?attr/colorPrimary"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurface"
            android:gravity="center"
            android:padding="@dimen/spacing_sm"
            android:visibility="gone"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCapture"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="📷 Scanner"
            style="@style/Widget.AlMizan.Button"
            app:cornerRadius="28dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirm"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="✅ Utiliser ce document"
            style="@style/Widget.AlMizan.Button.Outlined"
            android:visibility="gone"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
</file>

<file path="app/src/main/res/layout/activity_soumission.xml">
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        style="@style/Widget.AlMizan.Toolbar"
        app:title="@string/soumission_title"
        app:navigationIcon="@drawable/ic_back"/>

    <!-- TabLayout étapes -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:tabIndicatorColor="?attr/colorPrimary"
        app:tabIndicatorHeight="3dp"
        app:tabSelectedTextColor="?attr/colorPrimary"
        app:tabTextColor="?attr/colorOnSurfaceVariant"
        android:background="?attr/colorSurface"
        app:tabTextAppearance="?attr/textAppearanceLabelLarge"/>

    <!-- ViewPager -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:indeterminateTint="?attr/colorPrimary"
        android:visibility="gone"/>

    <!-- Navigation bas -->
