<file path="app/src/main/res/values/dimens.xml">
<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Spacing -->
    <dimen name="spacing_xs">4dp</dimen>
    <dimen name="spacing_sm">8dp</dimen>
    <dimen name="spacing_md">16dp</dimen>
    <dimen name="spacing_lg">24dp</dimen>
    <dimen name="spacing_xl">32dp</dimen>

    <!-- Corner radius (comme le web : rounded-xl = 12dp, rounded-2xl = 16dp) -->
    <dimen name="radius_sm">8dp</dimen>
    <dimen name="radius_md">12dp</dimen>
    <dimen name="radius_lg">16dp</dimen>
    <dimen name="radius_full">100dp</dimen>

    <!-- Card elevation -->
    <dimen name="elevation_card">2dp</dimen>
    <dimen name="elevation_bottom_nav">8dp</dimen>
    <dimen name="elevation_toolbar">4dp</dimen>

    <!-- Text sizes -->
