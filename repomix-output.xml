        binding = ActivityQuestionsBinding.inflate(layoutInflater)
        setContentView(binding.root)

        val marcheId = intent.getStringExtra("marche_id") ?: ""
        val marcheTitre = intent.getStringExtra("marche_titre") ?: ""

